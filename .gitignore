# Godot 4+ engine cache and generated files
.godot/
/android/

# NOTE: *.import files are deliberately NOT ignored.
#
# In Godot 3 the import cache lived in .import/ and was correctly excluded. In
# Godot 4 the cache is .godot/ (ignored above) and the per-asset *.import files
# are source metadata holding the stable resource UID plus import settings.
# Excluding them makes a fresh clone regenerate new UIDs, which silently breaks
# any resource referenced by UID. They belong in version control.

# Exported builds
/build/
/builds/
/export/
*.exe
*.pck
*.zip
*.dmg
*.app/

# Export credentials (NEVER commit — contains signing keys/passwords)
export_credentials.cfg

# Temp
*.tmp
*.tmp.*
.tmp/

# OS
.DS_Store
Thumbs.db

# Music generator intermediate lives in build/ (ignored above); only the
# encoded .ogg is committed under assets/.

# Python venv for the asset generators (tools/)
.venv/
